# ==============================================================================
#  SENTINEL XDR / AI-IDS — Backend Environment Template
#  Copy this file to `.env` and fill in your own keys. NEVER commit `.env`.
#  All LLM keys are backend-only and must NOT be exposed to the frontend.
# ==============================================================================

# ── LLM provider selection: nvidia | gemini | groq ────────────────────────────
LLM_PROVIDER=nvidia

# ── NVIDIA NIM (OpenAI-compatible) — primary ──────────────────────────────────
# Get a key at https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Google Gemini (optional fallback) ─────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Groq (optional fallback) ──────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Network / sniffer (optional) ──────────────────────────────────────────────
SNIFF_INTERFACE=Wi-Fi
